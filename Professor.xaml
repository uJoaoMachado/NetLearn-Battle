<Window x:Class="NetLearnBattle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetLearn Battle"
        Height="700"
        Width="1200">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu lateral -->
        <StackPanel Grid.Column="0" Background="#1E293B">

            <TextBlock Text="NetLearn Battle"
                       Foreground="White"
                       FontSize="20"
                       Margin="20"/>

            <Button Content="Painel"
                    Height="40"
                    Margin="10"
                    Click="BtnPainel_Click"/>

            <Button Content="Criar Sessão"
                    Height="40"
                    Margin="10"
                    Click="BtnSessao_Click"/>

            <Button Content="Estatísticas"
                    Height="40"
                    Margin="10"
                    Click="BtnStats_Click"/>

            <Button Content="Gestão ACL"
                    Height="40"
                    Margin="10"
                    Click="BtnAcl_Click"/>

        </StackPanel>


        <!-- Conteúdo -->
        <Grid Grid.Column="1">

            <!-- Painel -->
            <Grid x:Name="GridPainel">
                <TextBlock Text="Painel do Professor"
                           FontSize="30"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Sessão -->
            <Grid x:Name="GridSessao"
                  Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <TextBlock Text="Criar Sessão"
                               FontSize="30"/>

                    <TextBox x:Name="txtPorta"
                             Width="150"
                             Margin="10"/>

                    <Button Content="Iniciar Sessão"
                            Width="150"/>
                </StackPanel>
            </Grid>

            <!-- Estatísticas -->
            <Grid x:Name="GridStats"
                  Visibility="Collapsed">
                <TextBlock Text="Estatísticas"
                           FontSize="30"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- ACL -->
            <Grid x:Name="GridAcl"
                  Visibility="Collapsed">
                <TextBlock Text="Gestão de ACLs"
                           FontSize="30"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

        </Grid>

    </Grid>
</Window>