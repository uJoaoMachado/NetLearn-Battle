<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="netlearn.MainWindow"
        Title="NetLearn Game"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1B1033">

    <Grid RenderTransformOrigin="0.953,0.943">

        <!-- FUNDO GRADIENTE -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="Green" Offset="0"/>
                <GradientStop Color="Red" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- GRID PRINCIPAL -->
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <!-- HEADER -->
            <RowDefinition Height="*"/>
            <!-- CONTEÚDO -->
        </Grid.RowDefinitions>

        <!-- HEADER BONITO -->
        <Border Grid.Row="0"
                Margin="20,10,20,10"
                Background="#250B3C"
                CornerRadius="20"
                Padding="20"
                Effect="{StaticResource SoftShadow}">

            <DockPanel>

                <!-- TÍTULO -->
                <TextBlock Text="NetLearn Battle"
                           FontSize="32"
                           FontWeight="Black"
                           Foreground="White"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <!-- LADO DIREITO (RESERVADO PARA FUTURO) -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- ÁREA PRINCIPAL -->
        <Grid Grid.Row="1" Margin="20" RenderTransformOrigin="0.021,-0.008">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="0*"/>
                <!-- PERGUNTA -->
                <ColumnDefinition Width="2*"/>
                <!-- SCOREBOARD -->
            </Grid.ColumnDefinitions>

            <!-- CARTÃO DE PERGUNTA -->

            <!-- SCOREBOARD / LADO DIREITO -->
            <!-- CARTÃO TOP 5 -->
            <Border Background="#250B3C"
                        CornerRadius="25"
                        Padding="20"
                        Effect="{StaticResource SoftShadow}" Grid.Column="2" Margin="128,-4,0,316">
                <StackPanel>
                    <TextBlock Text="Top 5"
                                   FontSize="26"
                                   FontWeight="Black"
                                   Foreground="White"
                                   Margin="0 0 0 10"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Current Player"
                FontSize="18"
                FontWeight="Bold"
                Foreground="White" Margin="146,78,10,452" Grid.Column="2"/>
            <TextBlock Text="Store: Porto Norte"
                FontSize="14"
                Foreground="#C0B6FF"
                                   Margin="0,-68,242,603" Grid.Column="2"/>
            <TextBlock Text="Current Player"
                FontSize="18"
                FontWeight="Bold"
                Foreground="White" Margin="146,107,10,422" Grid.Column="2"/>
            <TextBlock Text="Current Player"
                FontSize="18"
                FontWeight="Bold"
                Foreground="White" Margin="146,137,10,393" Grid.Column="2"/>
            <TextBlock Text="Current Player"
                FontSize="18"
                FontWeight="Bold"
                Foreground="White" Margin="146,166,10,364" Grid.Column="2"/>
            <TextBlock Text="Current Player"
                FontSize="18"
                FontWeight="Bold"
                Foreground="White" Margin="146,195,10,335" Grid.Column="2"/>
            <Border Background="#250B3C"
                CornerRadius="25"
                Padding="20"
                Effect="{StaticResource SoftShadow}" Grid.Column="2" Margin="128,277,0,40">
                <StackPanel>
                    <TextBlock
                        FontSize="26"
                        FontWeight="Black"
                        Foreground="White"
                        Margin="0 0 0 10"/>
                </StackPanel>
            </Border>
            <Border Background="#250B3C"
                CornerRadius="25"
                Padding="20"
                Effect="{StaticResource SoftShadow}" Margin="0,0,353,335" Grid.ColumnSpan="3" RenderTransformOrigin="0.031,0.139">
                <StackPanel>
                    <TextBlock
                        FontSize="26"
                        FontWeight="Black"
                        Foreground="White"
                        Margin="0 0 0 10" Height="65"><Run Language="pt-pt" Text="Login"/></TextBlock>
                </StackPanel>
            </Border>
            <TextBlock
                FontSize="14"
                Foreground="WhiteSmoke"
                Margin="27,81,447,453"><Run Language="pt-pt" Text="Utilizador"/><LineBreak/><Run Language="pt-pt"/></TextBlock>
            <TextBlock
                FontSize="14"
                Foreground="WhiteSmoke"
                Margin="404,81,70,453"><Run Language="pt-pt" Text="Password"/><LineBreak/><Run Language="pt-pt"/></TextBlock>
            <Border Background="DarkGray"
                CornerRadius="25"
                Padding="20"
                Effect="{StaticResource SoftShadow}" Margin="27,109,348,408" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="-1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <TextBlock Height="0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Center"/>
            </Border>
            <Border Background="DarkGray"
                CornerRadius="25"
                Padding="20"
                Effect="{StaticResource SoftShadow}" Margin="404,109,435,408" RenderTransformOrigin="0.5,0.5" Grid.ColumnSpan="3">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="-1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <PasswordBox Height="0" VerticalAlignment="Center"/>
            </Border>
            <Border Background="#250B3C"
                CornerRadius="25"
                Padding="20"
                Effect="{StaticResource SoftShadow}" Margin="0,250,353,40" Grid.ColumnSpan="3" RenderTransformOrigin="0.031,0.139">
                <TextBlock
                        FontSize="26"
                        FontWeight="Black"
                        Foreground="White"
                        Margin="0,4,0,176"><Run Text="Registar"/><LineBreak/><Run/></TextBlock>
            </Border>
            <TextBlock
                FontSize="14"
                Foreground="WhiteSmoke"
                Margin="27,324,447,210"><Run Language="pt-pt" Text="Utilizador"/><LineBreak/><Run Language="pt-pt"/></TextBlock>
            <TextBlock
                FontSize="14"
                Foreground="WhiteSmoke"
                Margin="404,324,70,210"><Run Language="pt-pt" Text="Password"/><LineBreak/><Run Language="pt-pt"/></TextBlock>
            <Border Background="DarkGray"
                CornerRadius="25"
                Padding="20"
                Effect="{StaticResource SoftShadow}" Margin="27,356,348,161" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="-1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <TextBlock Height="0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Center"/>
            </Border>
            <Border Background="DarkGray"
                CornerRadius="25"
                Padding="20"
                Effect="{StaticResource SoftShadow}" Margin="404,356,435,161" RenderTransformOrigin="0.5,0.5" Grid.ColumnSpan="3">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="-1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <PasswordBox Height="0" VerticalAlignment="Center"/>
            </Border>

        </Grid>

    </Grid>
</Window>
